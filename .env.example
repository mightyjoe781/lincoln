# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver required. postgresql:// URLs are auto-rewritten at runtime.
# For local dev, point to localhost. For VPS/Docker, point to the service name.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lincoln

# ── PostgreSQL container credentials (VPS / Docker only) ─────────────────────
# Used by the lincoln-db container directly. Must match DATABASE_URL above.
POSTGRES_USER=lincoln
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lincoln

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/lincoln_uploads
MAX_UPLOAD_SIZE_BYTES=20971520

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT authentication ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Default admin user ────────────────────────────────────────────────────────
# Created automatically on container startup. Leave blank to skip.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ── Registration control ──────────────────────────────────────────────────────
# If set, POST /auth/register requires header: X-Registration-Token: <value>
# Leave blank to allow open registration.
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
REGISTRATION_TOKEN=

# ── Runtime / observability ───────────────────────────────────────────────────
ENVIRONMENT=development
# Used as a label in Prometheus and Grafana dashboards.
HOST_NAME=my-server
