# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver required. postgresql:// URLs are auto-rewritten at runtime.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lincoln

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/lincoln_uploads
MAX_UPLOAD_SIZE_BYTES=20971520

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT authentication ────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Default admin user ────────────────────────────────────────────────────────
# Created automatically on container startup. Leave blank to skip.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
